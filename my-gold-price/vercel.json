{
  "redirects": [
    {
      "source": "/blog/gold-post-:id*",
      "destination": "/blog",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        { "type": "host", "value": "(?!www\\.gold-tw\\.com).*\\.vercel\\.app" }
      ],
      "destination": "https://www.gold-tw.com/$1",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/hero.webp",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/logo.webp",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/_next/image(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/(.*)",
      "has": [
        { "type": "host", "value": "(?!www\\.gold-tw\\.com).*" }
      ],
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ]
}